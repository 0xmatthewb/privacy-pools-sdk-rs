{
  "name": "@0xmatthewb/privacy-pools-sdk",
  "version": "0.1.0-alpha.1",
  "private": false,
  "description": "Browser and Node package for the Privacy Pools SDK",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xmatthewb/privacy-pools-sdk-rs.git",
    "directory": "packages/sdk"
  },
  "type": "module",
  "main": "./src/node/index.mjs",
  "browser": "./src/browser/index.mjs",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "node": "./src/node/index.mjs",
      "browser": "./src/browser/index.mjs",
      "default": "./src/node/index.mjs"
    },
    "./worker": {
      "default": "./src/browser/worker.mjs"
    }
  },
  "scripts": {
    "build:native": "node ./scripts/build-native.mjs",
    "build:native:release": "node ./scripts/build-native.mjs --release",
    "build:web": "node ./scripts/build-web.mjs",
    "build:web:debug": "node ./scripts/build-web.mjs --debug",
    "build:web:release": "node ./scripts/build-web.mjs --release",
    "check:generated": "npm run build:web && node ./scripts/check-generated.mjs",
    "test": "npm run test:ci",
    "test:browser": "playwright test",
    "test:ci": "npm run build:native && npm run check:generated && npm run test:node && npm run test:browser",
    "test:node": "node --test ./test/*.test.mjs"
  },
  "files": [
    "src",
    "scripts",
    "test",
    "README.md",
    "package.json",
    "privacy_pools_sdk_node.node"
  ],
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
