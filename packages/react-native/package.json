{
  "name": "@0xbow/privacy-pools-sdk",
  "version": "0.1.0-alpha.1",
  "private": false,
  "description": "React Native bindings for the Rust-first Privacy Pools SDK",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xmatthewb/privacy-pools-sdk-rs.git",
    "directory": "packages/react-native"
  },
  "main": "./src/index.ts",
  "react-native": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "prepare:package": "cargo run -p xtask -- react-native-package",
